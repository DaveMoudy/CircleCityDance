---
const REGISTER_URL = 'https://app3.jackrabbitclass.com/regv2.asp?id=558073';

// Real CCD class data sourced from their published Summer Session I & II flyers.
// Schedule arrays are summer-current; replace/extend when fall season is published.
const classes = [
  {
    name: 'Discover Dance',
    ages: 'Ages 3 – 6',
    desc: 'A first taste of the studio — a little ballet, a little jazz, a little tap, all in one playful hour.',
    schedule: [
      { window: 'Summer Session I', days: 'Six dates in June', time: '5:00 – 5:30 pm' },
    ],
    tuition: '$100 / session',
    wear: 'Comfortable clothes the dancer can move in. Ballet slippers if you have them; bare feet are fine for week one.',
    notes: 'Drop-off class — parents welcome to wait in the lobby.',
  },
  {
    name: 'Jazz',
    ages: 'Ages 7+',
    desc: 'Lines, leaps, and personality. Classical jazz technique through to commercial style.',
    schedule: [
      { window: 'Summer Session I', days: 'Six dates in June', time: '5:30 – 6:15 pm' },
    ],
    tuition: '$120 / session',
    wear: 'Form-fitting top, leggings or jazz pants. Jazz shoes preferred; sneakers OK to start.',
  },
  {
    name: 'Tap',
    ages: 'Ages 7+',
    desc: 'Rhythm tap and Broadway. Where the music lives in the feet.',
    schedule: [
      { window: 'Summer Session I', days: 'Six dates in June', time: '6:15 – 7:00 pm' },
    ],
    tuition: '$120 / session',
    wear: 'Tap shoes required. Leggings or pants the dancer can move freely in.',
  },
  {
    name: 'Ballet Variations',
    ages: 'Intermediate +',
    desc: 'Classical foundation, modern feel — barre, center, and across-the-floor work for serious students.',
    schedule: [
      { window: 'Summer Session II', days: 'Tuesdays & Thursdays in July', time: '4:30 – 6:00 pm' },
    ],
    tuition: '$150 (6-class series)',
    wear: 'Leotard, tights, ballet slippers. Hair pulled back.',
    notes: 'Some prior ballet experience expected — message us if unsure of fit.',
  },
  {
    name: 'Leaps, Turns & Jazz Combo',
    ages: 'Ages 7+',
    desc: 'High-energy, fast-paced jazz that builds technical difficulty alongside performance quality.',
    schedule: [
      { window: 'Summer Session II', days: 'Tuesdays in July', time: '7:00 – 8:30 pm' },
    ],
    tuition: '$100 (4-class series)',
    wear: 'Form-fitting top, leggings, jazz shoes or bare feet.',
  },
  {
    name: 'Intro to Latin Dance',
    ages: 'Adult / Teens 10+',
    desc: 'Salsa, bachata, and merengue — partner work, lead-and-follow basics, sneakers welcome.',
    schedule: [
      { window: 'Summer Session II', days: 'Thursdays in July', time: '7:00 – 8:00 pm' },
    ],
    tuition: '$75 (4-class series)',
    wear: 'Sneakers, jazz shoes, character shoes, or ballroom-Latin heels — your call.',
    notes: 'No partner needed — we rotate so everyone leads and follows.',
  },
  {
    name: 'Pilates & Conditioning',
    ages: 'Dancers 10+',
    desc: 'Strength, flexibility, and injury prevention — foundational cross-training for working dancers.',
    schedule: [
      { window: 'Summer Session II', days: 'Tuesdays & Thursdays in July', time: '6:00 – 7:00 pm' },
    ],
    tuition: '$100 (4-class series)',
    wear: 'Form-fitting workout clothes. Bare feet or grip socks.',
  },
  {
    name: 'Pilates for Adults',
    ages: 'Adult',
    desc: 'Classical and elevated Pilates work that meets you where you are. No mat required.',
    schedule: [
      { window: 'Summer Session II', days: 'Tuesdays & Thursdays in July', time: '6:00 – 7:00 pm' },
    ],
    tuition: 'Drop-in & series rates — see Jackrabbit',
    wear: 'Anything you can move in. Bare feet or grip socks.',
    notes: 'Beginner-friendly. No previous Pilates experience required.',
  },
];

const ageGroups = [
  { range: '3 – 6', label: 'Discover Dance', desc: 'Creative movement, music, and a first taste of the studio.' },
  { range: '7 – 9', label: 'Junior', desc: 'Single-style training in jazz, tap, and ballet — real progression begins.' },
  { range: '10 – 13', label: 'Pre-Teen', desc: 'Intermediate technique plus dancer conditioning. Self-expression starts here.' },
  { range: '14 – 18', label: 'Senior', desc: 'Advanced training, audition prep, Performing Company opportunities.' },
  { range: 'Adult', label: 'Open & Latin', desc: 'Pilates for Adults and Intro to Latin Dance — open-level, drop-in welcome.' },
  { range: 'Camps', label: 'Summer', desc: 'Animal Adventure (3–6), Summer Performer\'s Camp (5–18), themed days, all summer long.' },
];
---

<section id="classes" class="section">
  <div class="container">
    <div class="grid lg:grid-cols-12 gap-10 mb-16">
      <div class="lg:col-span-7">
        <p class="eyebrow flex items-center" data-reveal><span class="rule"></span>04 / Classes</p>
        <h2 class="display mt-6 text-[clamp(2.4rem,5.6vw,5rem)] text-stage" data-headline-split>
          A class menu, <em>not</em> a buffet.
        </h2>
      </div>
      <p class="lg:col-span-4 lg:col-start-9 text-ink/70 leading-relaxed self-end" data-reveal>
        Click any class for schedule, tuition, and what to wear. Most students take two or three a week — faculty will help you build a fit.
      </p>
    </div>

    <!-- Class list (expandable) -->
    <div class="border-t border-line" data-reveal-stagger>
      {classes.map((c) => (
        <details class="class-row group border-b border-line" data-reveal-item>
          <summary
            class="flex flex-col md:flex-row md:items-baseline gap-4 md:gap-10 py-8 cursor-pointer list-none select-none"
          >
            <div class="md:w-1/3 flex items-baseline gap-4">
              <h3 class="font-display text-3xl md:text-5xl text-stage transition-colors group-hover:text-spotlight group-open:text-spotlight">
                {c.name}
              </h3>
            </div>
            <div class="md:flex-1 flex flex-col md:flex-row md:items-baseline gap-3 md:gap-8">
              <span class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-spotlight whitespace-nowrap">
                {c.ages}
              </span>
              <p class="text-ink/75 leading-relaxed max-w-xl">
                {c.desc}
              </p>
            </div>
            <span class="text-xs uppercase tracking-[0.2em] font-semibold text-spotlight md:self-center inline-flex items-center gap-2 whitespace-nowrap">
              <span class="group-open:hidden">Details</span>
              <span class="hidden group-open:inline">Close</span>
              <svg class="w-3 h-3 transition-transform duration-300 group-open:rotate-45" viewBox="0 0 12 12" aria-hidden="true">
                <line x1="6" y1="1" x2="6" y2="11" stroke="currentColor" stroke-width="1.5" />
                <line x1="1" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </span>
          </summary>

          <div class="class-row-detail">
            <div class="grid md:grid-cols-12 gap-6 md:gap-10 pb-10 md:pl-[33%]">
              <!-- Schedule -->
              <div class="md:col-span-7 space-y-4">
                <div class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-spotlight">Schedule</div>
                <ul class="space-y-3">
                  {c.schedule.map((s) => (
                    <li class="grid grid-cols-1 sm:grid-cols-3 gap-2 sm:gap-6 py-3 border-b border-line last:border-b-0">
                      <span class="font-display text-stage text-lg italic">{s.window}</span>
                      <span class="text-ink/70 text-sm leading-relaxed">{s.days}</span>
                      <span class="text-ink/70 text-sm leading-relaxed sm:text-right">{s.time}</span>
                    </li>
                  ))}
                </ul>
                <p class="text-stage/55 text-xs uppercase tracking-[0.22em] pt-1">
                  ↳ Fall season schedule lands soon.
                </p>
              </div>

              <!-- Sidebar info -->
              <aside class="md:col-span-5 space-y-5 md:pl-8 md:border-l border-line text-sm">
                <div>
                  <div class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-spotlight">Tuition</div>
                  <div class="font-display text-stage text-xl mt-1">{c.tuition}</div>
                </div>
                {c.wear && (
                  <div>
                    <div class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-spotlight">What to wear</div>
                    <p class="mt-1 text-ink/75 leading-relaxed">{c.wear}</p>
                  </div>
                )}
                {c.notes && (
                  <div>
                    <div class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-spotlight">Good to know</div>
                    <p class="mt-1 text-ink/75 leading-relaxed">{c.notes}</p>
                  </div>
                )}
                <a
                  href={REGISTER_URL}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-primary text-xs"
                >
                  Register
                  <span class="arrow" aria-hidden="true">→</span>
                </a>
              </aside>
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Age groups -->
    <div class="mt-24">
      <h3 class="font-display text-3xl text-stage mb-10" data-reveal>By age</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-line border border-line" data-reveal-stagger>
        {ageGroups.map((g) => (
          <div class="bg-cream p-7" data-reveal-item>
            <div class="flex items-baseline justify-between">
              <span class="font-display text-spotlight text-2xl italic">{g.range}</span>
              <span class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-stage/60">Ages</span>
            </div>
            <h4 class="mt-3 font-display text-2xl text-stage">{g.label}</h4>
            <p class="mt-3 text-ink/75 text-sm leading-relaxed">{g.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .class-row > summary::-webkit-details-marker { display: none; }
  .class-row > summary::marker { content: ''; }

  /* Smooth expand using grid trick — supported in all evergreen browsers in 2026. */
  .class-row-detail {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .class-row-detail > div {
    overflow: hidden;
  }
  .class-row[open] .class-row-detail {
    grid-template-rows: 1fr;
  }

  @media (prefers-reduced-motion: reduce) {
    .class-row-detail { transition: none; }
  }
</style>

<script>
  // Native <details> doesn't animate the close transition because it sets [open]=false
  // immediately, hiding content before our CSS transition runs. We delay the close
  // until the transition finishes.
  document.querySelectorAll<HTMLDetailsElement>('.class-row').forEach((el) => {
    const detail = el.querySelector<HTMLElement>('.class-row-detail');
    if (!detail) return;

    el.addEventListener('toggle', () => {
      // No-op — kept in case we want to react to open/close in the future.
    });

    // Intercept summary clicks to animate close before [open] flips off.
    const summary = el.querySelector<HTMLElement>('summary');
    summary?.addEventListener('click', (e) => {
      if (!el.open) return; // opening — let native behavior run
      e.preventDefault();
      detail.style.gridTemplateRows = '0fr';
      const onEnd = () => {
        el.open = false;
        detail.style.gridTemplateRows = '';
        detail.removeEventListener('transitionend', onEnd);
      };
      detail.addEventListener('transitionend', onEnd);
    });
  });
</script>
