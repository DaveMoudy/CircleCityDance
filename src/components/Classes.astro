---
// Real class menu pulled from CCD's published programming.
const classes = [
  { name: 'Discover Dance', ages: 'Ages 3 – 6', desc: 'A first taste of the studio — a little ballet, a little jazz, a little tap, all in one playful hour.' },
  { name: 'Jazz', ages: 'Ages 7+', desc: 'Lines, leaps, and personality. Classical jazz technique through to commercial style.' },
  { name: 'Tap', ages: 'Ages 7+', desc: 'Rhythm tap and Broadway. Where the music lives in the feet.' },
  { name: 'Ballet Variations', ages: 'Intermediate +', desc: 'Classical foundation, modern feel — barre, center, and across-the-floor work for serious students.' },
  { name: 'Leaps, Turns & Jazz Combo', ages: 'Ages 7+', desc: 'High-energy, fast-paced jazz that builds technical difficulty alongside performance quality.' },
  { name: 'Intro to Latin Dance', ages: 'Adult', desc: 'Salsa, bachata, and merengue — partner work, lead-and-follow basics, sneakers welcome.' },
  { name: 'Pilates & Conditioning', ages: 'Dancers 10+', desc: 'Strength, flexibility, and injury prevention — foundational cross-training for working dancers.' },
  { name: 'Pilates for Adults', ages: 'Adult', desc: 'Classical and elevated Pilates work that meets you where you are. No mat required.' },
];

const ageGroups = [
  { range: '3 – 6', label: 'Discover Dance', desc: 'Creative movement, music, and a first taste of the studio.' },
  { range: '7 – 9', label: 'Junior', desc: 'Single-style training in jazz, tap, and ballet — real progression begins.' },
  { range: '10 – 13', label: 'Pre-Teen', desc: 'Intermediate technique plus dancer conditioning. Self-expression starts here.' },
  { range: '14 – 18', label: 'Senior', desc: 'Advanced training, audition prep, Performing Company opportunities.' },
  { range: 'Adult', label: 'Open & Latin', desc: 'Pilates for Adults and Intro to Latin Dance — open-level, drop-in welcome.' },
  { range: 'Camps', label: 'Summer', desc: 'Animal Adventure (3–6), Summer Performer\'s Camp (5–18), themed days, all summer long.' },
];
---

<section id="classes" class="section">
  <div class="container">
    <div class="grid lg:grid-cols-12 gap-10 mb-16">
      <div class="lg:col-span-7">
        <p class="eyebrow flex items-center" data-reveal><span class="rule"></span>04 / Classes</p>
        <h2 class="display mt-6 text-[clamp(2.4rem,5.6vw,5rem)] text-stage" data-headline-split>
          A class menu, <em>not</em> a buffet.
        </h2>
      </div>
      <p class="lg:col-span-4 lg:col-start-9 text-ink/70 leading-relaxed self-end" data-reveal>
        Most students take two or three a week. Faculty will help you build a schedule that fits — and grows with you.
      </p>
    </div>

    <!-- Class list -->
    <div class="border-t border-line" data-reveal-stagger>
      {classes.map((s) => (
        <div
          class="group flex flex-col md:flex-row md:items-baseline gap-4 md:gap-10 py-8 border-b border-line cursor-default"
          data-reveal-item
        >
          <div class="md:w-1/3 flex items-baseline gap-4">
            <h3 class="font-display text-3xl md:text-5xl text-stage transition-colors group-hover:text-spotlight">
              {s.name}
            </h3>
          </div>
          <div class="md:flex-1 flex flex-col md:flex-row md:items-baseline gap-3 md:gap-8">
            <span class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-spotlight whitespace-nowrap">
              {s.ages}
            </span>
            <p class="text-ink/75 leading-relaxed max-w-xl">
              {s.desc}
            </p>
          </div>
          <span class="text-xs uppercase tracking-[0.2em] font-semibold text-spotlight md:self-center transition-transform group-hover:translate-x-1">
            View →
          </span>
        </div>
      ))}
    </div>

    <!-- Age groups -->
    <div class="mt-24">
      <h3 class="font-display text-3xl text-stage mb-10" data-reveal>By age</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-line border border-line" data-reveal-stagger>
        {ageGroups.map((g) => (
          <div class="bg-cream p-7" data-reveal-item>
            <div class="flex items-baseline justify-between">
              <span class="font-display text-spotlight text-2xl italic">{g.range}</span>
              <span class="text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-stage/60">Ages</span>
            </div>
            <h4 class="mt-3 font-display text-2xl text-stage">{g.label}</h4>
            <p class="mt-3 text-ink/75 text-sm leading-relaxed">{g.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
