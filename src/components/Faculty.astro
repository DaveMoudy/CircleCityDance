---
const faculty = [
  {
    role: 'Artistic Director',
    teaser: 'Setting the season, building the company, training the trainers.',
  },
  {
    role: 'Ballet Faculty',
    teaser: 'Classical foundation, modernly minded — barre work that meets the body it has.',
  },
  {
    role: 'Hip Hop Faculty',
    teaser: 'Rooted in the foundations and the freedom of the form.',
  },
  {
    role: 'Tap & Jazz Faculty',
    teaser: 'Rhythm in the feet, story in the line, musicality at the center.',
  },
];
---

<section id="faculty" class="section">
  <div class="container">
    <div class="grid lg:grid-cols-12 gap-10 mb-16">
      <div class="lg:col-span-7">
        <p class="eyebrow flex items-center" data-reveal><span class="rule"></span>06 / Faculty</p>
        <h2 class="display mt-6 text-[clamp(2.4rem,5.6vw,5rem)] text-stage" data-headline-split>
          Working artists. <em>Real</em> teachers.
        </h2>
      </div>
      <p class="lg:col-span-4 lg:col-start-9 text-ink/70 leading-relaxed self-end" data-reveal>
        Curating our founding faculty now. Real bios and headshots land here as artists are confirmed — and they will be working artists, every one of them.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5" data-reveal-stagger>
      {faculty.map((f, i) => (
        <article class="group" data-reveal-item>
          <div class="aspect-[4/5] bg-cream-deep relative overflow-hidden rounded-sm ring-1 ring-line">
            <div class="absolute inset-0 grid place-items-center text-stage/20">
              <svg viewBox="0 0 200 240" class="w-1/2" aria-hidden="true">
                <circle cx="100" cy="78" r="38" fill="currentColor" />
                <path d="M28 240 C28 160, 172 160, 172 240 Z" fill="currentColor" />
              </svg>
            </div>
            <div class="absolute top-4 left-4 text-[0.65rem] uppercase tracking-[0.22em] font-semibold text-spotlight">
              No. {String(i + 1).padStart(2, '0')}
            </div>
            <div class="absolute inset-x-0 bottom-0 p-4 text-[0.65rem] uppercase tracking-[0.22em] text-stage/45 font-semibold">
              Headshot — coming soon
            </div>
          </div>
          <h3 class="mt-5 font-display text-2xl text-stage transition-colors group-hover:text-spotlight">
            To be announced
          </h3>
          <div class="text-xs uppercase tracking-[0.2em] text-spotlight font-semibold mt-1">{f.role}</div>
          <p class="mt-3 text-sm text-ink/70 leading-relaxed">{f.teaser}</p>
        </article>
      ))}
    </div>

    <p class="mt-12 max-w-md text-sm text-stage/60 leading-relaxed border-l-2 border-spotlight pl-4" data-reveal>
      Want to teach with us? Email <a href="mailto:hello@circlecitydance.com" class="text-spotlight hover:underline">hello@circlecitydance.com</a> — we're hiring across styles.
    </p>
  </div>
</section>
