---
const links = [
  { href: '#programs', label: 'Programs' },
  { href: '#classes', label: 'Classes' },
  { href: '#schedule', label: 'Schedule' },
  { href: '#faculty', label: 'Faculty' },
  { href: '#performances', label: 'Performances' },
  { href: '#studio', label: 'Studio' },
  { href: '#visit', label: 'Visit' },
];
const REGISTER_URL = 'https://app3.jackrabbitclass.com/regv2.asp?id=558073';
const base = import.meta.env.BASE_URL;
---

<header
  data-nav
  class="fixed inset-x-0 top-0 z-50 transition-[background,backdrop-filter,padding] duration-500 py-5 data-[scrolled=true]:py-3 data-[scrolled=true]:bg-cream/85 data-[scrolled=true]:backdrop-blur-xl data-[scrolled=true]:shadow-[0_1px_0_0_rgba(15,21,48,0.06)]"
>
  <div class="container flex items-center justify-between gap-4">
    <a href="#top" class="flex items-center gap-3 group shrink-0">
      <span class="block h-9 w-9 rounded-full overflow-hidden bg-cream ring-1 ring-line">
        <img src={`${base}images/brand/logo-square.jpg`} alt="" class="h-full w-full object-cover" />
      </span>
      <span class="font-display text-stage text-lg sm:text-xl tracking-tight leading-none">
        Circle City <em class="not-italic text-spotlight">Dance</em>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-7 text-sm text-stage/80">
      {links.map((l) => (
        <a
          href={l.href}
          class="relative py-1 hover:text-spotlight transition-colors after:absolute after:left-0 after:bottom-0 after:h-px after:w-0 after:bg-spotlight after:transition-[width] after:duration-500 hover:after:w-full"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={REGISTER_URL}
        target="_blank"
        rel="noopener"
        class="btn btn-primary text-xs hidden sm:inline-flex"
        data-magnetic
      >
        Register
        <span class="arrow" aria-hidden="true">→</span>
      </a>

      <button
        data-menu-toggle
        type="button"
        class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-full ring-1 ring-line bg-cream text-stage hover:bg-stage hover:text-cream transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <span class="sr-only">Menu</span>
        <svg width="18" height="12" viewBox="0 0 18 12" aria-hidden="true">
          <line x1="0" y1="1" x2="18" y2="1" stroke="currentColor" stroke-width="1.5" />
          <line x1="0" y1="6" x2="18" y2="6" stroke="currentColor" stroke-width="1.5" />
          <line x1="0" y1="11" x2="18" y2="11" stroke="currentColor" stroke-width="1.5" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  data-menu-panel
  class="fixed inset-0 z-[60] bg-cream pointer-events-none opacity-0 transition-opacity duration-500 grain"
  aria-hidden="true"
>
  <div class="absolute top-5 right-5">
    <button
      data-menu-close
      type="button"
      class="inline-flex items-center justify-center h-10 w-10 rounded-full ring-1 ring-line bg-cream text-stage hover:bg-stage hover:text-cream transition-colors"
      aria-label="Close menu"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.5" />
        <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.5" />
      </svg>
    </button>
  </div>

  <div class="container h-full flex flex-col justify-center pt-20 pb-12">
    <p class="eyebrow mb-8">— Navigate</p>
    <ul class="space-y-3">
      {links.map((l, i) => (
        <li>
          <a
            href={l.href}
            data-menu-link
            class="font-display text-stage text-[clamp(2.4rem,9vw,4.5rem)] leading-[1] tracking-tight hover:text-spotlight transition-colors"
          >
            <span class="text-xs align-top mr-3 text-spotlight font-sans uppercase tracking-[0.25em] font-semibold">{String(i + 1).padStart(2, '0')}</span>
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-12 pt-8 border-t border-line flex flex-wrap items-center justify-between gap-4">
      <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary">
        Register
        <span class="arrow" aria-hidden="true">→</span>
      </a>
      <div class="flex items-center gap-4 text-sm text-stage/70">
        <a href="https://www.instagram.com/circlecitydance/" target="_blank" rel="noopener" class="hover:text-spotlight transition-colors">Instagram</a>
        <span class="opacity-30">/</span>
        <a href="https://www.facebook.com/profile.php?id=61582218223505" target="_blank" rel="noopener" class="hover:text-spotlight transition-colors">Facebook</a>
      </div>
    </div>
  </div>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const close = document.querySelector<HTMLButtonElement>('[data-menu-close]');
  const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-menu-link]');

  const open = () => {
    if (!panel || !toggle) return;
    panel.classList.remove('pointer-events-none', 'opacity-0');
    panel.classList.add('opacity-100');
    panel.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const dismiss = () => {
    if (!panel || !toggle) return;
    panel.classList.remove('opacity-100');
    panel.classList.add('pointer-events-none', 'opacity-0');
    panel.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', open);
  close?.addEventListener('click', dismiss);
  links.forEach((l) => l.addEventListener('click', () => setTimeout(dismiss, 50)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') dismiss();
  });
</script>
