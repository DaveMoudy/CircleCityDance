---
const REGISTER_URL = 'https://app3.jackrabbitclass.com/regv2.asp?id=558073';

const expect = [
  { num: 'i', body: 'Walk the studios — sprung floors, mirrors, the works.' },
  { num: 'ii', body: 'Meet faculty when they\'re between classes.' },
  { num: 'iii', body: 'Map your dancer\'s schedule together — no pressure to enroll.' },
];

const contacts = [
  { label: 'Address', primary: '4400 W 10th St', secondary: 'Indianapolis, IN 46222', href: 'https://maps.google.com/?q=4400+W+10th+St+Indianapolis+IN+46222' },
  { label: 'Phone', primary: '(317) 000-0000', secondary: 'Studio line — TBA', href: 'tel:+13170000000' },
  { label: 'Email', primary: 'hello@circlecitydance.com', secondary: 'We answer fast.', href: 'mailto:hello@circlecitydance.com' },
  { label: 'Hours', primary: 'Monday – Saturday', secondary: 'By class schedule' },
];
---

<section id="visit" class="section bg-cream-deep/60 relative overflow-hidden">
  <div
    aria-hidden="true"
    data-parallax="0.18"
    class="absolute -right-40 -bottom-32 w-[44rem] h-[44rem] rounded-full bg-spotlight/15 blur-3xl"
  ></div>
  <div
    aria-hidden="true"
    data-parallax="0.12"
    class="absolute -left-32 top-10 w-[32rem] h-[32rem] rounded-full bg-rose/40 blur-3xl"
  ></div>

  <div class="container relative">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Left: headline + tour pitch -->
      <div class="lg:col-span-7">
        <p class="eyebrow flex items-center" data-reveal>
          <span class="rule"></span>10 / Visit
        </p>
        <h2 class="display mt-6 text-[clamp(2.6rem,7vw,7rem)] text-stage" data-headline-split>
          Come <em>see</em> the place.
        </h2>
        <p class="mt-8 text-ink/75 text-lg leading-relaxed max-w-lg" data-reveal>
          Studio tours are open by appointment — just reach out. We'll show you around, walk through the season with you, and answer every question in the book.
        </p>

        <div class="mt-10 flex flex-wrap gap-4" data-reveal>
          <a href={REGISTER_URL} target="_blank" rel="noopener" class="btn btn-primary" data-magnetic>
            Register
            <span class="arrow" aria-hidden="true">→</span>
          </a>
          <a href="mailto:hello@circlecitydance.com?subject=Studio%20Tour" class="btn btn-ghost">
            Book a tour
          </a>
        </div>

        <!-- What to expect -->
        <div class="mt-14 border-t border-line pt-8" data-reveal>
          <p class="eyebrow flex items-center mb-6">
            <span class="rule"></span>What to expect
          </p>
          <ol class="grid sm:grid-cols-3 gap-px bg-line border border-line rounded-sm overflow-hidden">
            {expect.map((e) => (
              <li class="bg-cream p-5">
                <div class="font-display italic text-spotlight text-2xl">{e.num}.</div>
                <p class="mt-2 text-sm text-ink/80 leading-snug">{e.body}</p>
              </li>
            ))}
          </ol>
        </div>

        <!-- Closing thought -->
        <p class="mt-10 max-w-md font-display italic text-stage text-2xl leading-snug border-l-2 border-spotlight pl-5" data-reveal>
          The first class is on us. Bring the dancer, leave the pressure.
        </p>
      </div>

      <!-- Right: vertical contact stack -->
      <aside class="lg:col-span-4 lg:col-start-9 lg:sticky lg:top-32 self-start space-y-1" data-reveal>
        <div class="bg-cream rounded-sm border border-line overflow-hidden">
          {contacts.map((c, i) => (
            <div class={`p-6 ${i > 0 ? 'border-t border-line' : ''}`}>
              <dt class="text-[0.65rem] uppercase tracking-[0.22em] text-spotlight font-semibold">{c.label}</dt>
              <dd class="mt-2 font-display text-stage leading-tight">
                {c.href ? (
                  <a href={c.href} class="text-lg sm:text-xl hover:text-spotlight transition-colors">{c.primary}</a>
                ) : (
                  <span class="text-lg sm:text-xl">{c.primary}</span>
                )}
                <span class="block text-stage/55 text-sm font-sans mt-1">{c.secondary}</span>
              </dd>
            </div>
          ))}
        </div>

        <!-- Live map -->
        <a
          href="https://maps.google.com/?q=4400+W+10th+St+Indianapolis+IN+46222"
          target="_blank"
          rel="noopener"
          class="mt-6 group block rounded-sm border border-line overflow-hidden bg-cream relative aspect-[5/3]"
          aria-label="Open Circle City Dance in Google Maps"
        >
          <iframe
            title="Map of Circle City Dance — 4400 W 10th St, Indianapolis, IN"
            src="https://maps.google.com/maps?q=4400+W+10th+St+Indianapolis+IN+46222&t=&z=15&ie=UTF8&iwloc=&output=embed"
            class="absolute inset-0 w-full h-full border-0 grayscale-[20%] contrast-95 transition group-hover:grayscale-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <span class="absolute top-3 left-3 inline-flex items-center gap-2 bg-cream/95 text-stage text-[0.65rem] uppercase tracking-[0.22em] font-semibold px-3 py-1.5 rounded-full ring-1 ring-line">
            <span class="block w-1.5 h-1.5 rounded-full bg-spotlight"></span>
            4400 W 10th · Open in Maps →
          </span>
        </a>

        <div class="mt-6 flex items-center gap-5 text-sm text-stage/70 px-1">
          <span class="text-[0.65rem] uppercase tracking-[0.22em] text-spotlight font-semibold">Follow</span>
          <a href="https://www.instagram.com/circlecitydance/" target="_blank" rel="noopener" class="hover:text-spotlight transition-colors">Instagram</a>
          <span class="opacity-30">/</span>
          <a href="https://www.facebook.com/profile.php?id=61582218223505" target="_blank" rel="noopener" class="hover:text-spotlight transition-colors">Facebook</a>
        </div>
      </aside>
    </div>
  </div>
</section>
