---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Circle City Dance — Indianapolis',
  description = 'A new home for dance in Indianapolis. Classes for every age and stage, taught by working artists who love the work as much as you will.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#FAF6F0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/brand/logo-square.jpg" />
    <link rel="icon" type="image/jpeg" href="/images/brand/logo-square.jpg" />
    <title>{title}</title>
  </head>
  <body class="grain">
    <slot />
    <script>
      import '../lib/motion.ts';
    </script>
  </body>
</html>
