---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const tiers = [
  {
    n: 'i',
    label: 'Launch essentials',
    headline: 'The pieces we need to take the site live, publicly.',
    intro:
      "These are the things visitors expect and we can't fake. Three of them are five-minute asks. Get these in and we set the site loose.",
    groups: [
      {
        title: 'Contact info',
        place: 'Lives in: the Visit section + footer',
        items: [
          { label: 'Studio phone number', detail: 'Currently a placeholder reading (317) 000-0000.' },
          { label: 'Best email for inquiries', detail: 'We\'ve mocked hello@circlecitydance.com — set it up if it doesn\'t exist yet, or tell us what to use instead.' },
          { label: 'Studio hours', detail: 'When are doors open? When does the registration desk staff?' },
          { label: 'Confirm address — 4400 W 10th St, Indianapolis, IN 46222', detail: 'Already wired into the live Google Map. Just want a confirmation.', done: true },
        ],
      },
      {
        title: 'Social handles',
        place: 'Lives in: nav, footer, gallery — anywhere we link out',
        items: [
          { label: 'Confirm Instagram is @circlecitydance' },
          { label: 'Confirm Facebook page URL is correct', detail: 'We have facebook.com/profile.php?id=61582218223505 — let us know if there\'s a vanity URL.' },
        ],
      },
      {
        title: 'Social share image',
        place: 'Lives in: invisible meta tags. High impact for word-of-mouth.',
        items: [
          { label: 'One 1200×630 JPG or PNG', detail: 'What appears when someone shares the site link in iMessage, Facebook, Slack. Could be the studio banner, a hero photo, or the logo on a navy background.' },
        ],
      },
    ],
  },
  {
    n: 'ii',
    label: 'Elevators',
    headline: 'These take the site from "nice template" to "feels like us."',
    intro:
      'The biggest single jump in perceived quality comes from real faculty and real photography. Phone shots are fine — we\'ll handle styling.',
    groups: [
      {
        title: 'Faculty',
        place: 'Lives in: the Faculty section. Currently shows four "To be announced" placeholders.',
        items: [
          { label: 'Full name', detail: 'For each instructor.' },
          { label: 'Role / title', detail: '"Artistic Director", "Ballet Faculty", "Hip Hop Faculty", etc.' },
          { label: 'Headshot', detail: 'Vertical or square, ideally 1200px+ on the long edge. Phone photos are fine if well-lit.' },
          { label: 'Two-to-three sentence bio', detail: 'Where they trained, what they perform/choreograph, what they bring to the studio. Voice can be casual or formal — your call.' },
          { label: 'Optional: teaching philosophy or favorite class to teach', detail: 'A single line, used as a pull quote.' },
        ],
      },
      {
        title: 'Studio photography',
        place: 'Lives in: the Studio section, Gallery, and possibly the Hero.',
        items: [
          { label: 'One wide interior shot of a studio', detail: 'Sprung floor + mirrors visible, lights on, empty room, clean lines.' },
          { label: 'One shot of the lobby / family waiting area' },
          { label: 'One in-class shot', detail: 'Students mid-movement. A little motion blur is great.' },
          { label: 'One detail shot', detail: 'Pointe shoes on a barre, a row of tap shoes, sheet music, anything texture-rich.' },
          { label: 'Bonus: candid student or parent photos', detail: 'Vision Board photo from the FB page is already in use ✓' },
        ],
      },
      {
        title: 'Logo files',
        place: 'Vector files let us use the brand cleanly at every size.',
        items: [
          { label: 'Vector logo', detail: '.svg, .ai, or .pdf of the round red-dancer mark.' },
          { label: 'Vector wordmark', detail: '.svg of the "Circle City Dance" stacked text.' },
          { label: 'Horizontal CCD lockup', detail: 'The navy-bg version we found on Facebook, ideally as .svg or PNG with transparency.' },
          { label: 'Optional: one-color variants', detail: 'White-on-navy and red-on-cream, for varied placements.' },
        ],
      },
    ],
  },
  {
    n: 'iii',
    label: 'Programming',
    headline: 'The details that fill in the rhythm of a real studio year.',
    intro:
      'The site already shows real Summer Session I & II content harvested from your FB flyers. Once fall is finalized, this is where we fold it in.',
    groups: [
      {
        title: 'Fall season schedule',
        place: 'Lives in: the Classes section, expandable detail panels.',
        items: [
          { label: 'Class list', detail: 'What\'s offered fall through spring.' },
          { label: 'Days + times for each class' },
          { label: 'Tuition', detail: 'Monthly rate or per-class rate.' },
          { label: 'Instructor assigned to each class', detail: 'Will link to the matching faculty bio.' },
          { label: 'Age and level requirements' },
        ],
      },
      {
        title: 'Performances',
        place: 'Lives in: the Performances section. The Nutcracker is already the signature card.',
        items: [
          { label: 'The Nutcracker — performance dates and venue' },
          { label: 'Spring Recital — date and venue' },
          { label: 'Winter Showcase — if applicable' },
          { label: 'Audition dates for Performing Companies' },
        ],
      },
      {
        title: 'Tuition & policies',
        items: [
          { label: 'Master tuition table', detail: 'Multi-class discounts, sibling discounts, registration fees, costume fees, recital fees — anything a parent should know upfront.' },
          { label: 'Refund / drop policy', detail: 'A short blurb is plenty.' },
        ],
      },
      {
        title: 'Jackrabbit class IDs',
        place: 'Optional but powerful — saves families a click.',
        items: [
          { label: 'Per-class IDs from your Jackrabbit admin', detail: 'Lets us deep-link each "Register" button straight to that class\'s enrollment page instead of the main schedule.' },
        ],
      },
    ],
  },
  {
    n: 'iv',
    label: 'Voice & story',
    headline: 'What makes the site feel like this studio, not any studio.',
    intro:
      'The hardest stuff to fake — and the stuff that makes families choose you over the place down the road.',
    groups: [
      {
        title: 'Founding story',
        place: 'Could expand the Welcome section or earn its own /about page.',
        items: [
          { label: 'Why you started CCD', detail: 'Three or four sentences, first-person if you want. What was missing in Indy that you\'re filling? What\'s the studio\'s reason for being?' },
          { label: 'Optional: a founder photo' },
        ],
      },
      {
        title: 'Quotes & testimonials',
        place: 'Will live in a new "Voices" section once you have material.',
        items: [
          { label: 'Two to four short quotes', detail: 'Once you have them — from parents, students, or guest artists. One sentence each. Attribution like "Sarah, parent of a 7-year-old."' },
        ],
      },
      {
        title: 'Press & partnerships',
        items: [
          { label: 'Any press mentions, partnerships, or community ties', detail: 'Guest choreographers, partner studios, Nutcracker production partners, anything worth flagging.' },
        ],
      },
    ],
  },
  {
    n: 'v',
    label: 'Big swings',
    headline: 'Optional. Only if you want to go all the way.',
    intro:
      'These take the site from beautiful to remembered. None are required — the site is fully strong without them.',
    groups: [
      {
        title: 'Hero video loop',
        items: [
          { label: 'A 5–8 second silent video loop', detail: 'Dancers in your space. Slow motion or natural speed both work. MP4, 1080p+, under 5 MB. Replaces the current hero typography moment with something cinematic.' },
        ],
      },
      {
        title: 'Lead capture & tools',
        items: [
          { label: 'Trial class / tour request form fields', detail: 'Right now "Book a tour" opens an email. We can replace with a real form — confirm the fields you want (name, email, phone, dancer\'s age, style of interest...) and where submissions should land.' },
          { label: 'Newsletter or waitlist signup?', detail: 'If yes — Mailchimp, ConvertKit, a Google Form, or just an inbox? We\'ll add a footer signup field.' },
          { label: 'Hiring page', detail: 'The site already says you\'re hiring. If you want a dedicated /teach page, send us: which styles, the application process, any non-negotiables.' },
        ],
      },
      {
        title: 'Custom domain',
        items: [
          { label: 'Buy circlecitydance.com (or .studio, .dance, etc.)', detail: '~$15/year. Live URL becomes clean. We can wire DNS in ten minutes once purchased.' },
        ],
      },
      {
        title: 'Ongoing content pipeline',
        items: [
          { label: 'A steady stream of studio photos / Reels', detail: 'We can pull these into the Gallery section as the year goes on.' },
          { label: 'Optional: a "Studio Notes" blog', detail: 'If you\'d write occasionally — recital wraps, faculty spotlights, season announcements.' },
        ],
      },
    ],
  },
];
---

<Base
  title="Circle City Dance — Studio asset checklist"
  description="A tiered punch list of everything we need from the studio to make the site fully theirs."
>
  <header class="border-b border-line bg-cream">
    <div class="container py-5 flex items-center justify-between">
      <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-3 group shrink-0">
        <span class="block h-9 w-9 rounded-full overflow-hidden bg-cream ring-1 ring-line">
          <img src={`${import.meta.env.BASE_URL}images/brand/logo-square.jpg`} alt="" class="h-full w-full object-cover" />
        </span>
        <span class="font-display text-stage text-lg sm:text-xl tracking-tight leading-none">
          Circle City <em class="not-italic text-spotlight">Dance</em>
        </span>
      </a>
      <a href={`${import.meta.env.BASE_URL}`} class="text-sm text-stage/70 hover:text-spotlight transition-colors hidden sm:inline-flex items-center gap-2">
        <span aria-hidden="true">←</span> Back to the site
      </a>
      <button onclick="window.print()" class="text-xs uppercase tracking-[0.22em] font-semibold text-spotlight hover:text-stage transition-colors no-print">
        Print
      </button>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="section pt-20 pb-16">
      <div class="container">
        <p class="eyebrow flex items-center mb-6">
          <span class="rule"></span>For the studio team
        </p>
        <h1 class="display text-stage text-[clamp(2.6rem,7vw,7rem)] max-w-4xl">
          A short list of <em>things we need</em> to make the site really sing.
        </h1>
        <div class="mt-12 grid lg:grid-cols-12 gap-10 items-start">
          <div class="lg:col-span-7 space-y-5 text-lg leading-relaxed text-ink/80">
            <p>
              The site is live with placeholders where your real info will go. Below is a tiered punch list — top of the page is launch-essential, bottom is optional. Send what you have, in any format. <span class="text-stage font-medium">Don't worry about file formats, sizing, or polish.</span> We'll handle the rest.
            </p>
            <p>
              Email everything to a single thread, or drop files in a shared Google Drive folder named <span class="font-display italic text-stage">"CCD Site Assets"</span> — your call.
            </p>
          </div>
          <aside class="lg:col-span-4 lg:col-start-9 bg-cream-deep/60 rounded-sm border border-line p-6 text-sm">
            <p class="text-[0.65rem] uppercase tracking-[0.22em] text-spotlight font-semibold mb-3">In this document</p>
            <ol class="space-y-2 text-stage/80">
              {tiers.map((t) => (
                <li>
                  <a href={`#tier-${t.n}`} class="hover:text-spotlight transition-colors flex items-baseline gap-3">
                    <span class="font-display italic text-spotlight">{t.n}.</span>
                    <span>{t.label}</span>
                  </a>
                </li>
              ))}
            </ol>
            <p class="mt-5 pt-5 border-t border-line text-stage/55 text-xs">
              Updated {today}
            </p>
          </aside>
        </div>
      </div>
    </section>

    <!-- Tiers -->
    {tiers.map((tier, ti) => (
      <section id={`tier-${tier.n}`} class={`section ${ti % 2 === 0 ? '' : 'bg-cream-deep/40'} relative overflow-hidden`}>
        <div class="container">
          <div class="grid lg:grid-cols-12 gap-10 mb-14 items-end">
            <div class="lg:col-span-9">
              <p class="eyebrow flex items-center">
                <span class="rule"></span>Tier {tier.n} — {tier.label}
              </p>
              <h2 class="display mt-6 text-[clamp(2.2rem,5vw,4.5rem)] text-stage">
                <span class="font-display italic text-spotlight mr-3">{tier.n}.</span>
                {tier.headline}
              </h2>
            </div>
            <p class="lg:col-span-3 text-ink/70 leading-relaxed text-base">
              {tier.intro}
            </p>
          </div>

          <div class="space-y-12">
            {tier.groups.map((g) => (
              <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
                <div class="lg:col-span-4">
                  <h3 class="font-display text-2xl lg:text-3xl text-stage leading-tight">
                    {g.title}
                  </h3>
                  {g.place && (
                    <p class="mt-3 text-stage/55 text-xs uppercase tracking-[0.22em] font-semibold">
                      ↳ {g.place}
                    </p>
                  )}
                </div>
                <ol class="lg:col-span-8 space-y-px bg-line border border-line rounded-sm overflow-hidden">
                  {g.items.map((item) => (
                    <li class={`bg-cream p-5 sm:p-6 flex gap-5 ${item.done ? 'opacity-70' : ''}`}>
                      <span
                        class={`mt-1 inline-flex shrink-0 items-center justify-center h-6 w-6 rounded-sm border-2 ${item.done ? 'border-spotlight bg-spotlight text-cream' : 'border-stage/30 text-transparent'}`}
                        aria-hidden="true"
                      >
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <path d="M2 7.5 L5.5 11 L12 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                      <div class="flex-1">
                        <p class={`font-display text-stage text-lg leading-snug ${item.done ? 'line-through decoration-stage/30' : ''}`}>
                          {item.label}
                        </p>
                        {item.detail && (
                          <p class="mt-1.5 text-sm text-ink/70 leading-relaxed">
                            {item.detail}
                          </p>
                        )}
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    <!-- Closing -->
    <section class="section">
      <div class="container">
        <div class="max-w-3xl">
          <p class="eyebrow flex items-center">
            <span class="rule"></span>One last thing
          </p>
          <h2 class="display mt-6 text-[clamp(2rem,4.5vw,4rem)] text-stage">
            Send raw. <em>We'll handle</em> the styling.
          </h2>
          <p class="mt-8 text-lg leading-relaxed text-ink/80 max-w-2xl">
            Phone photos beat no photos. Notes beat no notes. A spreadsheet of class times beats a perfect schedule that's three weeks away. The site is wired to absorb whatever you have today and look better tomorrow when more arrives.
          </p>
          <p class="mt-6 font-display italic text-2xl text-stage border-l-2 border-spotlight pl-5 max-w-2xl">
            When everything in Tier i is in, we go live on the custom domain and turn on social-share polish. Tiers ii through v we layer in as content arrives.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  @media print {
    .no-print { display: none !important; }
    header { border-bottom: 1px solid #ddd !important; }
    .section { padding: 1.5rem 0 !important; break-inside: avoid; }
    .display { font-size: 2rem !important; }
    body { background: white !important; }
    .grain::after { display: none !important; }
  }
</style>
